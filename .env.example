# Base URLs for the Approved Platform (AP) services
PA_BASE_URL_FLOW=https://api.flow.votre-pa.fr/flow-service
PA_BASE_URL_DIRECTORY=https://api.directory.votre-pa.fr/directory-service

# OAuth2 client_credentials credentials (provided by the AP)
PA_CLIENT_ID=xxx
PA_CLIENT_SECRET=xxx

# OAuth2 token URL of the AP
PA_TOKEN_URL=https://auth.votre-pa.fr/oauth/token

# OAuth2 scope shared by both services (used if per-service scopes below are not set)
PA_OAUTH_SCOPE=

# Per-service OAuth2 scopes (optional; override PA_OAUTH_SCOPE for each service independently)
# Set these when your AP issues different scopes for the Flow and Directory services.
PA_OAUTH_SCOPE_FLOW=
PA_OAUTH_SCOPE_DIRECTORY=

# HTTP timeout in seconds (default: 30)
HTTP_TIMEOUT=30

# Enable debug logging (true/false)
DEBUG=false
