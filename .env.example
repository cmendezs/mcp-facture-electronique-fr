# URL de base des services de la Plateforme Agréée (PA)
PA_BASE_URL_FLOW=https://api.flow.votre-pa.fr/flow-service
PA_BASE_URL_DIRECTORY=https://api.directory.votre-pa.fr/directory-service

# Identifiants OAuth2 client_credentials (fournis par la PA)
PA_CLIENT_ID=xxx
PA_CLIENT_SECRET=xxx

# URL du token OAuth2 de la PA
PA_TOKEN_URL=https://auth.votre-pa.fr/oauth/token

# Scope OAuth2 (optionnel, laisser vide si non requis par la PA)
PA_OAUTH_SCOPE=

# Timeout HTTP en secondes (défaut : 30)
HTTP_TIMEOUT=30

# Activer les logs de débogage (true/false)
DEBUG=false
